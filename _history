        basic.showLeds(`\n            # # # # #\n            # # # # #\n            # # # # #\n            # # # # #\n            # # # # #\n            `)\n    }\n    // 5. Wartezeit vor der nächsten Messung\n    basic.pause(2000)\n})\n","README.md":"","main.py":"def on_forever():\n    pass\nbasic.forever(on_forever)\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n","pxt.json":"{\n    \"name\": \"wwww\",\n    \"description\": \"\",\n    \"dependencies\": {\n        \"core\": \"*\",\n        \"v2\": \"*\",\n        \"grove\": \"github:calliope-edu/pxt-grove#v0.9.5\"\n    },\n    \"files\": [\n        \"main.blocks\",\n        \"main.ts\",\n        \"README.md\",\n        \"main.py\"\n    ],\n    \"preferredEditor\": \"tsprj\"\n}\n"}}],"shares":[],"lastSaveTime":1777273246162}